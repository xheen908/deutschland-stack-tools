{
  "name": "deutschland-stack-tools",
  "version": "1.0.0",
  "description": "ODF & PDF/UA compliance validator for Germany's Deutschland-Stack",
  "bin": {
    "dst": "./bin/dst"
  },
  "scripts": {
    "build": "tsc && cp src/ocr/*.py dist/ocr/ 2>/dev/null || true",
    "dev": "ts-node src/index.ts serve",
    "serve": "node dist/index.js serve",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t deutschland-stack-tools .",
    "docker:run": "docker run -p 3000:3000 deutschland-stack-tools"
  },
  "dependencies": {
    "@fastify/multipart": "^8.x",
    "@fastify/rate-limit": "^9.x",
    "commander": "^12.x",
    "fastify": "^4.x",
    "pino": "^9.x",
    "pino-pretty": "^11.x",
    "puppeteer": "^25.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.x",
    "@types/node": "^24.x",
    "eslint": "^9.x",
    "jest": "^29.x",
    "ts-jest": "^29.x",
    "typescript": "^5.x",
    "typescript-eslint": "^8.61.1"
  },
  "keywords": [
    "odf",
    "pdf-ua",
    "validator",
    "deutschland-stack",
    "open-source",
    "compliance",
    "verwaltung",
    "digitale-souveraenität"
  ],
  "license": "MIT"
}
